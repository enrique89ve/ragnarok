    "react-syntax-highlighter": "^15.5.0",
    "simplex-noise": "^4.0.3",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.4",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-animated": "^2.0.0",
    "ts-jest": "^29.3.2",
    "ts-morph": "^25.0.1",
    "ts-node": "^10.9.2",
