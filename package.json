{
  "name": "norse-mythos-card-game",
  "version": "1.2.0",
  "description": "Ragnarok: Norse Mythos Card Game — 2,400+ cards, 80 heroes, poker combat, Hive NFT blockchain",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "CHOKIDAR_USEPOLLING=1 tsx server/index.ts",
    "dev:game": "npm run dev",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:static": "vite build",
    "build:packs": "node scripts/buildAssetPacks.mjs",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "node scripts/run-eslint.mjs",
    "lint:fix": "node scripts/run-eslint.mjs --fix",
    "lint:css": "stylelint 'client/src/**/*.css' --max-warnings=0",
    "lint:css:dupes": "node scripts/check-css-cross-file-dupes.mjs",
    "lint:css:dupes:baseline": "node scripts/check-css-cross-file-dupes.mjs --baseline",
    "lint:css:dupes:infile": "node scripts/check-css-infile-dupes.mjs",
    "lint:css:dupes:infile:baseline": "node scripts/check-css-infile-dupes.mjs --baseline",
    "db:push": "drizzle-kit push",
    "db:setup": "tsx server/setupDatabase.ts",
    "db:seed": "tsx server/seedCardSupply.ts",
    "db:seed-packs": "tsx server/seedPackTypes.ts",
    "build:wasm": "asc assembly/index.ts -o client/public/engine.wasm -t client/public/engine.wat --optimize --noAssert --runtime stub --exportRuntime --bindings esm",
    "build:wasm:debug": "asc assembly/index.ts -o client/public/engine.wasm -t client/public/engine.wat --debug --runtime stub --exportRuntime --bindings esm",
    "prepare": "husky"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.25",
    "@modelcontextprotocol/sdk": "^1.10.1",
    "@neondatabase/serverless": "^0.10.4",
    "@octokit/rest": "^22.0.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
