#!/usr/bin/env sh
# Defensive: unset any inherited NODE_OPTIONS first. tsx and similar dev
# tooling can leave experimental flags in the environment that newer node
# versions reject (e.g. --harmony-import-attributes). Forcing a clean
# slate before re-setting our own option avoids "bad option" failures.
#
# Heap size: 8GB. eslint with the React + TS plugins gets OOM-killed
# under 4GB when 12+ files land in a single batch (large content/feature
# commits regularly hit this — see the campaign authoring sprint).
unset NODE_OPTIONS
export NODE_OPTIONS="--max-old-space-size=8192"
node scripts/run-lint-staged.mjs
