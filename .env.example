# Database Configuration (PostgreSQL / Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
PGHOST=your-db-host.neon.tech
PGPORT=5432
PGUSER=your_db_user
PGPASSWORD=your_db_password
PGDATABASE=your_db_name

# Session Secret (generate a random string)
SESSION_SECRET=your-session-secret-here

# Ragnarok runtime environment
# VITE_NETWORK_STAGE controls permanence:
# - local: private development, resettable, can use mocks/catalog access
# - testnet: shared beta network, resettable, validates full architecture
# - mainnet: permanent economic environment
VITE_NETWORK_STAGE=local

# VITE_DATA_LAYER_MODE controls where game/economy data comes from:
# - local: local browser/dev data
# - test: mock/test server data
# - hive: Hive L1 replay/indexed data
VITE_DATA_LAYER_MODE=local

# Enables packaging match results for chain/replay flows when supported.
VITE_BLOCKCHAIN_PACKAGING=false

# Optional per-network overrides. Defaults are defined in client/src/game/config/networkConfig.ts.
# VITE_RAGNAROK_PROTOCOL_ID is the normal shared source for browser + server namespace.
# VITE_RAGNAROK_PROTOCOL_ID=rk_game_testnet
# VITE_RAGNAROK_COLLECTION_ID=ragnarok-testnet
# VITE_RAGNAROK_ADMIN_ACCOUNT=ragnarok-test
# VITE_RAGNAROK_GENESIS_ACCOUNT=ragnarok-test
# VITE_RAGNAROK_TREASURY_ACCOUNT=ragnarok-test
# VITE_RAGNAROK_INDEX_ACCOUNT=ragnarok-test-index
# VITE_RAGNAROK_INDEXER_URL=https://testnet-indexer.example.com
# VITE_RAGNAROK_ART_INDEXER_URL=https://testnet-art.example.com
# VITE_NFTLOX_PROTOCOL_ID=nftlox_testnet
# VITE_NFT_ART_BASE_URL=https://dhenz14.github.io/norse-mythos-card-game
# VITE_EXTERNAL_URL_BASE=https://dhenz14.github.io/norse-mythos-card-game

# Optional server/operator-only override for split deployments.
# If unset, server code should fall back to VITE_RAGNAROK_PROTOCOL_ID.
# RAGNAROK_PROTOCOL_ID=rk_game_testnet

# Claude Code API (optional - for scripts/automation)
# ANTHROPIC_API_KEY=sk-ant-...

# Cloudinary (optional - for card art hosting)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Multiplayer (optional - PeerJS uses free public server by default)
# To self-host a PeerJS signaling server, set these:
# PEER_SERVER_HOST=your-peer-server.com
# PEER_SERVER_PORT=9000
# PEER_SERVER_PATH=/myapp
